# PostgreSQL
POSTGRES_USER=mediconnect
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=mediconnect

# LiveKit - this must be the PUBLIC URL your browser can reach
# For production: wss://livekit.yourdomain.com or ws://YOUR_SERVER_IP:7880
LIVEKIT_PUBLIC_URL=ws://YOUR_SERVER_IP:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=CHANGE_ME_generate_a_secret

# MinIO
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=CHANGE_ME_strong_password_here

# Better Auth
BETTER_AUTH_SECRET=CHANGE_ME_generate_a_random_string
BETTER_AUTH_URL=http://YOUR_SERVER_IP:3000
